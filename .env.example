# =============================================================================
# betX – Configuration
# =============================================================================

# -- API Keys (données sportives) --
# API-Football (https://www.api-football.com/)
API_FOOTBALL_KEY=your_api_football_key_here
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# API-Tennis (optionnel, ou autre source)
API_TENNIS_KEY=your_api_tennis_key_here

# API-Basketball (optionnel, ou autre source)
API_BASKETBALL_KEY=your_api_basketball_key_here

# -- Odds API (https://the-odds-api.com/) --
ODDS_API_KEY=your_odds_api_key_here
ODDS_API_BASE_URL=https://api.the-odds-api.com/v4

# -- Base de données --
DATABASE_URL=sqlite:///data/betx.db

# -- Bankroll --
INITIAL_BANKROLL=1000.0

# -- Telegram Bot (notifications quotidiennes) --
# 1. Ouvre Telegram → @BotFather → /newbot
# 2. Copie le token ci-dessous
# 3. Envoie /start à ton bot
# 4. Lance: python daily_scan.py --get-chat-id
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# -- Logging --
LOG_LEVEL=INFO
